<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xsi:type="TaskPaneApp">
<Id>4daf41fe-f111-47cc-ac4a-aed1a97eb0fd</Id>
<Version>1.0.0.0</Version>
<ProviderName>Diprem IT</ProviderName>
<DefaultLocale>es-AR</DefaultLocale>
<DisplayName DefaultValue="HelpDesk IT"/>
<Description DefaultValue="Soporte tecnico y creacion de usuarios Diprem"/>
<IconUrl DefaultValue="https://timespc.github.io/helpdesk/icon-80.png"/>
<HighResolutionIconUrl DefaultValue="https://timespc.github.io/helpdesk/icon-80.png"/>
<SupportUrl DefaultValue="https://timespc.github.io/helpdesk"/>
<AppDomains>
<AppDomain>timespc.github.io</AppDomain>
<AppDomain>forms.office.com</AppDomain>
</AppDomains>
<Hosts>
<Host Name="Document"/>
<Host Name="Workbook"/>
<Host Name="Mailbox"/>
</Hosts>
<DefaultSettings>
<SourceLocation DefaultValue="https://timespc.github.io/helpdesk"/>
</DefaultSettings>
<Permissions>ReadWriteDocument</Permissions>
<VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
<Hosts>
<Host xsi:type="Document">
<DesktopFormFactor>
<ExtensionPoint xsi:type="PrimaryCommandSurface">
<OfficeTab id="TabHome">
<Group id="grpWord">
<Label resid="grpLabel"/>
<Control xsi:type="Button" id="btnWord">
<Label resid="btnLabel"/>
<Supertip>
<Title resid="btnLabel"/>
<Description resid="btnDesc"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="img16"/>
<bt:Image size="32" resid="img32"/>
<bt:Image size="80" resid="img80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<TaskpaneId>paneWord</TaskpaneId>
<SourceLocation resid="appUrl"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
<Host xsi:type="Workbook">
<DesktopFormFactor>
<ExtensionPoint xsi:type="PrimaryCommandSurface">
<OfficeTab id="TabHome">
<Group id="grpExcel">
<Label resid="grpLabel"/>
<Control xsi:type="Button" id="btnExcel">
<Label resid="btnLabel"/>
<Supertip>
<Title resid="btnLabel"/>
<Description resid="btnDesc"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="img16"/>
<bt:Image size="32" resid="img32"/>
<bt:Image size="80" resid="img80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<TaskpaneId>paneExcel</TaskpaneId>
<SourceLocation resid="appUrl"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
<Host xsi:type="MailHost">
<DesktopFormFactor>
<FunctionFile resid="appUrl"/>
<ExtensionPoint xsi:type="MessageReadCommandSurface">
<OfficeTab id="TabDefault">
<Group id="grpOutlookRead">
<Label resid="grpLabel"/>
<Control xsi:type="Button" id="btnOutlookRead">
<Label resid="btnLabel"/>
<Supertip>
<Title resid="btnLabel"/>
<Description resid="btnDesc"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="img16"/>
<bt:Image size="32" resid="img32"/>
<bt:Image size="80" resid="img80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<TaskpaneId>paneOutlookRead</TaskpaneId>
<SourceLocation resid="appUrl"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
<ExtensionPoint xsi:type="MessageComposeCommandSurface">
<OfficeTab id="TabDefault">
<Group id="grpOutlookCompose">
<Label resid="grpLabel"/>
<Control xsi:type="Button" id="btnOutlookCompose">
<Label resid="btnLabel"/>
<Supertip>
<Title resid="btnLabel"/>
<Description resid="btnDesc"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="img16"/>
<bt:Image size="32" resid="img32"/>
<bt:Image size="80" resid="img80"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<TaskpaneId>paneOutlookCompose</TaskpaneId>
<SourceLocation resid="appUrl"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
</Hosts>
<Resources>
<bt:Images>
<bt:Image id="img16" DefaultValue="https://timespc.github.io/helpdesk/icon-16.png"/>
<bt:Image id="img32" DefaultValue="https://timespc.github.io/helpdesk/icon-32.png"/>
<bt:Image id="img80" DefaultValue="https://timespc.github.io/helpdesk/icon-80.png"/>
</bt:Images>
<bt:Urls>
<bt:Url id="appUrl" DefaultValue="https://timespc.github.io/helpdesk"/>
</bt:Urls>
<bt:ShortStrings>
<bt:String id="grpLabel" DefaultValue="HelpDesk IT"/>
<bt:String id="btnLabel" DefaultValue="HelpDesk IT"/>
</bt:ShortStrings>
<bt:LongStrings>
<bt:String id="btnDesc" DefaultValue="Abrir chatbot de soporte tecnico IT de Diprem"/>
</bt:LongStrings>
</Resources>
</VersionOverrides>
</OfficeApp>
